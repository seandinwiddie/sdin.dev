{
  "name": "sdin-dev",
  "private": true,
  "description": "Portable static build for the sdin.dev remote-development brand.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "generate": "node ./scripts/generate-metadata.mjs && npm run build:sitemap",
    "build": "npm run generate && npm run build:css && npm run build:dist",
    "build:css": "tailwindcss -i ./src/input.css -o ./tailwind.css --minify",
    "build:sitemap": "node ./scripts/generate-sitemaps.mjs",
    "build:dist": "node ./scripts/build-dist.mjs",
    "check": "node ./scripts/check-site.mjs",
    "verify": "npm run build && npm run check"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "6.7.2",
    "aos": "2.3.1",
    "tailwindcss": "3.4.17"
  }
}
